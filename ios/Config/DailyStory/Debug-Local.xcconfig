REQUIRES_CAMERA = NO
DAILY_REMINDER_NOTIFICATION_ID = daily-story.daily-reminder

DEBUG_INFORMATION_FORMAT = dwarf
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG PRODUCT_STORY
SWIFT_OPTIMIZATION_LEVEL = -Onone
